# tutorials/.env.example
#
# Copy to tutorials/.env (which is gitignored) and fill in whichever
# keys you have. Each tutorial uses a subset; you do NOT need all of
# them. See docs/eda_agents_setup.md for the per-tutorial requirements.

# ---------------------------------------------------------------------
# Tutorial 01 (TUI agent) — pick ONE of these paths.
# ---------------------------------------------------------------------
# Option A: Claude Code CLI + Anthropic subscription
#   No env var needed; the `claude` binary uses ~/.claude/ on disk.
#
# Option B: opencode CLI + a provider API key
#   You must have ONE of OPENROUTER_API_KEY / GOOGLE_API_KEY / ZAI_API_KEY.

# ---------------------------------------------------------------------
# Tutorial 02 (Python API) — pick ONE backend.
# ---------------------------------------------------------------------
# Option A: backend="cc_cli"  (free with Claude subscription)
#   Same as T01 Option A: needs `claude` binary on PATH; no env var.
#
# Option B: backend="adk"     (uses an LLM API key)
#   Needs OPENROUTER_API_KEY (or GOOGLE_API_KEY) below.

# ---------------------------------------------------------------------
# Tutorial 03 (Autoresearch) — needs an LLM API key.
# ---------------------------------------------------------------------
# Default backend="opencode" with Gemini Flash, cheapest option for
# greedy multi-eval loops. Required env var:
#   OPENROUTER_API_KEY=...

# ---- API keys ----
# OpenRouter (cheapest path to Gemini Flash, GPT-4o, Claude, etc.)
# Sign up: https://openrouter.ai/  (pay-as-you-go, ~$0.075/1M tokens for Gemini Flash)
OPENROUTER_API_KEY=

# Google AI Studio (Gemini direct)
# Sign up: https://aistudio.google.com/  (free tier available)
GOOGLE_API_KEY=

# Z.ai (Zhipu, GLM-4.6, fast + cheap)
# Sign up: https://z.ai/
ZAI_API_KEY=

# ---- Optional model override ----
# Default model used by tutorials 02 and 03. Override to test other
# providers. Examples:
#   "google/gemini-3-flash-preview"  (default, cheap)
#   "anthropic/claude-haiku-4-5"     (fast, mid-cost)
#   "openai/gpt-4o-mini"             (mid-cost)
EDA_AGENTS_MODEL=

# ---- Tutorial 02 cc_cli backend dangerous-permissions gate ----
# When tutorial 02 runs with BACKEND="cc_cli" (Claude subscription path),
# the agent is launched as a non-interactive `claude --print` subprocess.
# Tool calls (docker exec, file read) hit Claude Code's permission layer
# with no human to approve, so they refuse / hang unless we pass the
# --dangerously-skip-permissions flag. Double-gated for safety: requires
# BOTH this env var AND the in-script RUN_DANGEROUSLY=True toggle.
# Only set this in the shell where you launch the tutorial; it does not
# need to be persistent.
EDA_AGENTS_ALLOW_DANGEROUS=
